  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; margin: 24px 0 32px; }
  .stat-box { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 16px; text-align: center; }
  .stat-val { font-size: 1.8em; font-weight: 800; color: var(--accent); }
  .stat-label { font-size: 0.72em; text-transform: uppercase; letter-spacing: 1px; color: var(--text-secondary); margin-top: 4px; }

  .section-title { font-size: 1.05em; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px;
    color: var(--accent); margin: 32px 0 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }

  .timeline-item { display: grid; grid-template-columns: 90px 1fr auto; gap: 0 16px; padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.04); align-items: start; }
