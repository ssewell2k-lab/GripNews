  </div>
</section>

<script>
const API = 'https://gripai.uk/v2';
const ITEM_TYPE = 'game';
const ITEM_ID = '<?= e($slug) ?>';

(async () => {
  try {
    const r = await fetch(`${API}/reactions/${ITEM_TYPE}/${encodeURIComponent(ITEM_ID)}`);
    const d = await r.json();
    if (d.counts) {
      Object.entries(d.counts).forEach(([emoji, cnt]) => {
        const el = document.getElementById(`count-${emoji}`);
        if (el && cnt > 0) el.textContent = cnt;
      });
    }
  } catch(e) {}
})();

async function sendFeedback(emoji) {
  try {
    const r = await fetch(`${API}/reactions`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ item_type: ITEM_TYPE, item_id: ITEM_ID, emoji })
    });
    const d = await r.json();
    ['useful','not_useful','fire','eyes'].forEach(e => {
      const el = document.getElementById(`count-${e}`);
      if (el) el.textContent = d.counts?.[e] || '';
    });
    document.querySelectorAll('.fb-btn').forEach(b => b.classList.remove('fb-active'));
    if (d.action === 'added') {
      document.querySelector(`[data-emoji="${emoji}"]`)?.classList.add('fb-active');
    }
    document.getElementById('feedback-thanks').style.display = 'flex';
    setTimeout(() => { document.getElementById('feedback-thanks').style.display = 'none'; }, 3000);
  } catch(e) {}
}
</script>

<?php require_once __DIR__ . '/includes/footer.php'; ?>

<script>
  var API = "https://gripai.uk/v2";
  var SLUG = "<?= $slug ?>";

  function esc(s) {
    var d = document.createElement("div");
    d.textContent = s || "";
    return d.innerHTML;
  }

  function impactClass(sc) {
    if (sc >= 7) return "high";
    if (sc >= 4) return "mid";
    return "low";
  }

  function catColor(cat) {
    var map = { industry: "#00e676", patch: "#ffc107", rumor: "#ab47bc", esports: "#42a5f5", meta_shift: "#ff5722" };
    return map[(cat || "").toLowerCase()] || "#00e676";
  }

  Promise.all([
    fetch(API + "/game/" + SLUG).then(function(r) { return r.json(); }),
    fetch(API + "/game/" + SLUG + "/meta").then(function(r) { return r.json(); }),
    fetch(API + "/game/" + SLUG + "/timeline").then(function(r) { return r.json(); }),
    fetch(API + "/game/" + SLUG + "/reliability").then(function(r) { return r.json(); })
  ]).then(function(results) {
    var game = results[0];
    var meta = results[1];
    var timeline = results[2];
    var reliability = results[3];

    document.getElementById("game-loading").style.display = "none";

    // Health badge
    if (meta.health_score !== undefined) {
      var label = meta.health_label || "Unknown";
      document.getElementById("health-container").innerHTML =
        '<span class="health-badge health-' + label + '">' + label.toUpperCase() + ' · ' + meta.health_score + '/100</span>';
    }

    // Stats grid
    var stats = document.getElementById("stats-container");
    var evCount = (game.events && game.events.count) || 0;
    var sigCount = (game.signals && game.signals.count) || 0;
    var issTotal = (game.issues && game.issues.total) || 0;
    var issCrit = (game.issues && (parseInt(game.issues.critical) || 0)) || 0;
    var avgImp = (meta.events && meta.events.avg_impact) ? parseFloat(meta.events.avg_impact).toFixed(1) : "—";
    var peakImp = (meta.events && meta.events.peak_impact) || "—";

    stats.innerHTML =
      '<div class="stat-box"><div class="stat-val">' + evCount + '</div><div class="stat-label">Events</div></div>' +
      '<div class="stat-box"><div class="stat-val">' + sigCount + '</div><div class="stat-label">Active Signals</div></div>' +
      '<div class="stat-box"><div class="stat-val">' + issTotal + '</div><div class="stat-label">Issues Tracked</div></div>' +
      '<div class="stat-box"><div class="stat-val">' + issCrit + '</div><div class="stat-label">Critical</div></div>' +
      '<div class="stat-box"><div class="stat-val">' + avgImp + '</div><div class="stat-label">Avg Impact</div></div>' +
      '<div class="stat-box"><div class="stat-val">' + peakImp + '</div><div class="stat-label">Peak Impact</div></div>';

    // Events — improved "what changed / why it matters" structure
    var events = (game.events && game.events.recent) || [];
    if (events.length) {
      document.getElementById("events-section").style.display = "block";
      var evHtml = "";
      events.forEach(function(ev) {
        var imp = ev.impact || {};
        var sc = Math.max(imp.player || 0, imp.dev || 0, imp.esports || 0, imp.industry || 0);
        var col = catColor(ev.type);

        evHtml += '<div class="event-card-mini">' +
          '<div class="ecm-header">' +
            '<div class="ecm-title">' + esc(ev.title) + '</div>' +
            '<div class="ecm-score ' + impactClass(sc) + '">' + sc + '</div>' +
          '</div>' +
          '<div class="ecm-fact">' + esc(ev.summary) + '</div>';

        if (ev.why_it_matters) {
          evHtml += '<div class="ecm-why">↳ ' + esc(ev.why_it_matters) + '</div>';
        }

        var strengthLabel = ev.signal_strength || "developing";
        evHtml += '<div class="ecm-meta">' +
          '<span class="ecm-type-tag" style="background:' + col + '20;color:' + col + '">' + esc(ev.type || ev.category) + '</span>' +
          '<span class="ecm-conf">' + esc(ev.confidence) + '</span>' +
          '<span class="strength-badge strength-' + strengthLabel + '">' + strengthLabel + '</span>' +
          '</div>';

        evHtml += '<button class="ecm-expand" onclick="expandEvent(\'' + esc(ev.event_id) + '\', this)">🧠 Ask GripAI</button>' +
          '<div class="depth-inline" id="depth-game-' + esc(ev.event_id) + '"></div>';

        evHtml += '</div>';
      });
      document.getElementById("events-list").innerHTML = evHtml;
    }

    // Timeline
    var tl = timeline.timeline || [];
    if (tl.length) {
      document.getElementById("timeline-section").style.display = "block";
      var tlHtml = "";
      tl.forEach(function(t) {
        var dateStr = (t.event_date || "").split("T")[0];
        var col = catColor(t.event_type);
        tlHtml += '<div class="timeline-item">' +
          '<span class="tl-date">' + esc(dateStr) + '</span>' +
          '<div><span class="tl-title">' + esc(t.title) + '</span>' +
          '<span class="tl-type" style="background:' + col + '15;color:' + col + '">' + esc(t.event_type) + '</span></div>' +
          '<span class="tl-impact ' + impactClass(t.impact_score) + '">' + (t.impact_score || 0) + '</span>' +
          '</div>';
      });
      document.getElementById("timeline-list").innerHTML = tlHtml;
    }

    // Signals
    var sigs = (game.signals && game.signals.active) || [];
    if (sigs.length) {
      document.getElementById("signals-section").style.display = "block";
      var sigHtml = "";
      sigs.forEach(function(s) {
        sigHtml += '<div class="cluster-card">' +
          '<div class="cluster-label">' + esc(s.signal_type || s.type) + '</div>' +
          '<div class="cluster-meta">Severity: ' + esc(s.severity) + ' · Confidence: ' + (s.confidence || "—") + ' · Detected: ' + esc((s.first_detected || "").split("T")[0]) + '</div>' +
          '</div>';
      });
      document.getElementById("signals-list").innerHTML = sigHtml;
    }

    // Clusters
    var clusters = game.clusters || [];
    if (clusters.length) {
      document.getElementById("clusters-section").style.display = "block";
      var clHtml = "";
      clusters.forEach(function(c) {
        clHtml += '<div class="cluster-card">' +
          '<div class="cluster-label">' + esc(c.label) + '</div>' +
          '<div class="cluster-meta">' + c.issue_count + ' issues · ' + esc(c.category) + ' · ' + esc(c.status) + '</div>';
        if (c.fixes && c.fixes.length) {
          clHtml += '<div class="cluster-fixes">💡 ' + c.fixes.slice(0, 2).map(esc).join(" · ") + '</div>';
        }
        clHtml += '</div>';
      });
      document.getElementById("clusters-list").innerHTML = clHtml;
    }

    // Reliability (Day 6)
    if (reliability && reliability.events) {
      var rv = reliability.events;
      var rs = reliability.signals || {};
      document.getElementById("reliability-section").style.display = "block";
      document.getElementById("reliability-grid").innerHTML =
        '<div class="stat-box reliability-strong"><div class="stat-val">' + (rv.strong || 0) + '</div><div class="stat-label">Strong Events</div></div>' +
        '<div class="stat-box reliability-developing"><div class="stat-val">' + (rv.developing || 0) + '</div><div class="stat-label">Developing</div></div>' +
        '<div class="stat-box reliability-weak"><div class="stat-val">' + (rv.weak || 0) + '</div><div class="stat-label">Weak</div></div>' +
        '<div class="stat-box"><div class="stat-val">' + (rv.avg_confidence || 0) + '</div><div class="stat-label">Avg Confidence</div></div>' +
        '<div class="stat-box"><div class="stat-val">' + (rv.avg_evidence || 0) + '</div><div class="stat-label">Avg Evidence</div></div>' +
        '<div class="stat-box"><div class="stat-val">' + (rv.avg_sources || 0) + '</div><div class="stat-label">Avg Sources</div></div>';
    }

  }).catch(function(err) {
    document.getElementById("game-loading").innerHTML =
      '<p style="color:#ffc107;">Unable to load game data right now. <a href="/" style="color:var(--accent);">Return to feed</a></p>';
  });

  // Expand event depth
  window.expandEvent = function(eventId, btn) {
    var panel = document.getElementById("depth-game-" + eventId);
    if (!panel) return;
    if (panel.dataset.loaded === "1") { panel.classList.toggle("open"); return; }

    btn.textContent = "⏳ Analysing…";
    btn.disabled = true;

    fetch(API + "/news/event/" + eventId)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var ev = data.event || {};
        var detail = ev.detail || [];
        var html = '<h4>🔍 Deep Analysis</h4>';
        if (detail.length) {
          detail.forEach(function(d) { html += '<p>' + esc(d) + '</p>'; });
        }
        if (ev.jaffaai_insight) {
          html += '<h4>🧠 JaffaAI Insight</h4><p>' + esc(ev.jaffaai_insight) + '</p>';
        }
        var imp = ev.impact || {};
        html += '<h4>📊 Impact Breakdown</h4><div class="impact-breakdown">';
        ["player","dev","esports","industry"].forEach(function(k) {
          var v = imp[k] || 0;
          var cls = v >= 7 ? "high" : (v >= 4 ? "mid" : "");
          html += '<span class="impact-chip ' + cls + '">' + k.charAt(0).toUpperCase() + k.slice(1) + ': ' + v + '/10</span>';
        });
        html += '</div>';

        var realSources = (ev.sources || []).filter(function(s) { return s.url && s.url.indexOf("example.com") === -1; });
        if (realSources.length) {
          html += '<h4>📎 Sources</h4>';
          realSources.forEach(function(src) {
            html += '<a href="' + esc(src.url) + '" target="_blank" style="color:var(--accent);font-size:0.85em;display:block;margin-top:4px;">' + esc(src.name || src.url) + ' →</a>';
          });
        }

        panel.innerHTML = html;
        panel.dataset.loaded = "1";
        panel.classList.add("open");
        btn.textContent = "🧠 GripAI Analysis ▾";
        btn.disabled = false;
      }).catch(function() {
        panel.innerHTML = '<p style="color:#ffc107;">Unable to load analysis right now.</p>';
        panel.classList.add("open");
        btn.textContent = "🧠 Ask GripAI";
        btn.disabled = false;
      });
  };
</script>
