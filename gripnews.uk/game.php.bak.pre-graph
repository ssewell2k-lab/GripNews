  .event-card-mini { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
    padding: 16px 20px; margin-bottom: 12px; transition: border-color 0.2s; }
  .event-card-mini:hover { border-color: var(--accent); }
  .ecm-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
  .ecm-title { font-weight: 700; color: var(--text-primary); flex: 1; }
  .ecm-score { font-size: 1.3em; font-weight: 800; flex-shrink: 0; }
