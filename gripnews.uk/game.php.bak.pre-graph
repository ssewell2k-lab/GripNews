  .ecm-type-tag { font-size: 0.68em; text-transform: uppercase; padding: 2px 8px; border-radius: 4px;
    font-weight: 700; letter-spacing: 0.5px; }
  .ecm-conf { font-size: 0.75em; color: var(--text-secondary); }
  .ecm-expand { background: none; border: 1px solid var(--accent); color: var(--accent); padding: 4px 12px;
    border-radius: 6px; font-size: 0.78em; cursor: pointer; font-weight: 600; margin-top: 8px; transition: all 0.2s; }
  .ecm-expand:hover { background: var(--accent); color: #000; }

  .depth-inline { display: none; background: rgba(0,230,118,0.04); border: 1px solid rgba(0,230,118,0.12);
    border-radius: 8px; padding: 16px 20px; margin-top: 10px; font-size: 0.88em; line-height: 1.6; color: var(--text-secondary); }
  .depth-inline.open { display: block; }
  .depth-inline h4 { color: var(--accent); font-size: 0.82em; text-transform: uppercase; letter-spacing: 1px; margin: 14px 0 6px; }
  .depth-inline h4:first-child { margin-top: 0; }
  .depth-inline p { margin: 6px 0; }
  .impact-chip { display: inline-block; padding: 3px 10px; border-radius: 4px; font-size: 0.78em;
    font-family: var(--mono); margin: 2px 4px 2px 0; border: 1px solid rgba(255,255,255,0.08); }
  .impact-chip.high { border-color: rgba(244,67,54,0.4); color: #f44336; }
  .impact-chip.mid { border-color: rgba(255,193,7,0.4); color: #ffc107; }

  .cluster-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px;
    padding: 14px 18px; margin-bottom: 10px; }
  .cluster-label { font-weight: 700; color: var(--text-primary); font-size: 0.92em; }
  .cluster-meta { font-size: 0.78em; color: var(--text-secondary); margin-top: 4px; }
  .cluster-fixes { font-size: 0.82em; color: var(--cyan, #26c6da); margin-top: 6px; }

  .strength-badge { display: inline-block; padding: 2px 10px; border-radius: 12px; font-size: 0.65em;
    font-weight: 700; letter-spacing: 0.8px; text-transform: uppercase; margin-left: 8px; vertical-align: middle; }
  .strength-strong { background: rgba(0,230,118,0.12); color: #00e676; border: 1px solid rgba(0,230,118,0.3); }
  .strength-developing { background: rgba(255,193,7,0.12); color: #ffc107; border: 1px solid rgba(255,193,7,0.3); }
  .strength-weak { background: rgba(255,255,255,0.06); color: var(--text-secondary); border: 1px solid rgba(255,255,255,0.1); }
  .reliability-strong .stat-val { color: #00e676; }
  .reliability-developing .stat-val { color: #ffc107; }
  .reliability-weak .stat-val { color: var(--text-secondary); }

  .loader-game { text-align: center; padding: 60px 0; color: var(--text-secondary); }
  .loader-game .pulse { display: inline-block; width: 10px; height: 10px; border-radius: 50%;
    background: var(--accent); animation: pulse 1s infinite; }
  .back-link { color: var(--accent); text-decoration: none; font-size: 0.85em; display: inline-block; margin-bottom: 8px; }
  .back-link:hover { text-decoration: underline; }
</style>

