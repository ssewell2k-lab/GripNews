<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8">
  <meta name="robots" content="noindex, nofollow">

  
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>GripAi — Authentication</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <meta name="description" content="GripAi unified authentication. Sign in to access jaffaAi, GameAi, Grip Protocol, and the full GripAi ecosystem.">


</head>
<body>
<!-- Loading Screen -->
<div id="page-loader">
  <div class="loader-inner">
    <div class="loader-ring"></div>
    <div class="loader-brand">GRIP<span>AI</span></div>
  </div>
</div>
<style>
  #page-loader {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: #0B0E17;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }
  #page-loader.fade-out {
    opacity: 0;
    visibility: hidden;
  }
  .loader-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }
  .loader-ring {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(0, 212, 255, 0.15);
    border-top-color: #00d4ff;
    border-radius: 50%;
    animation: loader-spin 0.8s linear infinite;
  }
  @keyframes loader-spin {
    to { transform: rotate(360deg); }
  }
  .loader-brand {
    font-family: Manrope, -apple-system, sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.35);
  }
  .loader-brand span {
    color: #00d4ff;
  }
</style>
<script>
  (function() {
    var loader = document.getElementById("page-loader");
    var maxTime = setTimeout(function() { loader.classList.add("fade-out"); }, 3000);
    window.addEventListener("load", function() {
      clearTimeout(maxTime);
      loader.classList.add("fade-out");
    });
  })();
</script>

<!-- Background Effects -->
<div class="bg-grid"></div>
<div class="bg-glow"></div>

<!-- Header -->
<header class="site-header">
  <div class="logo">
    <svg width="28" height="28" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="14" stroke="#00d4ff" stroke-width="2"/><path d="M10 16l4 4 8-8" stroke="#00d4ff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    <span class="logo-text">GripAi Auth</span>
  </div>
  <nav class="nav-links">
    <a href="https://gripai.uk">GripAi</a>
    <a href="https://gameai.uk">GameAi</a>
    <a href="https://jaffaai.co.uk">jaffaAi</a>
  </nav>
</header>

<!-- Main Content -->
<div class="main-container">
  <!-- Left: Hero -->
  <div class="hero-section">
    <div class="hero-badge">🔒 AUTH v0.6.2</div>
    <h1>One account.<br>Full ecosystem.</h1>
    <p class="hero-subtitle">
      Sign in once to access jaffaAi, GameAi, Grip Protocol, the API, and everything in the GripAi ecosystem.
    </p>

    <div class="feature-list">
      <div class="feature">
        <span class="feature-icon">🛡️</span>
        <div><strong>Secured by GripCaptcha</strong><span>Our own CAPTCHA system — no Google, no tracking</span></div>
      </div>
      <div class="feature">
        <span class="feature-icon">🔑</span>
        <div><strong>JWT Tokens</strong><span>Short-lived access + rotatable refresh tokens</span></div>
      </div>
      <div class="feature">
        <span class="feature-icon">⚡</span>
        <div><strong>SSO Ready</strong><span>Sign in once, access everything across the ecosystem</span></div>
      </div>
    </div>

    <div class="endpoint-list">
      <div class="endpoint"><span class="method post">POST</span><code>/auth/login</code></div>
      <div class="endpoint"><span class="method post">POST</span><code>/auth/register</code></div>
      <div class="endpoint"><span class="method post">POST</span><code>/auth/refresh</code></div>
      <div class="endpoint"><span class="method get">GET</span><code>/health</code></div>
    </div>

    <div style="margin-top:1.5rem;">
      <span id="service-status" class="status-dot"></span>
      <span id="service-status-text" style="font-size:0.8rem;color:var(--text-muted);margin-left:0.5rem;">Checking...</span>
    </div>
  </div>

  <!-- Right: Auth Card -->
  <div class="auth-card">
    <div class="auth-tabs">
      <button class="tab-btn active" data-tab="login">Sign In</button>
      <button class="tab-btn" data-tab="register">Create Account</button>
    </div>

    <!-- Login Form -->
    <form id="login-form" class="auth-form active" autocomplete="on">
      <div class="form-group">
        <label for="login-email">Email</label>
        <input type="email" id="login-email" required autocomplete="email" placeholder="you@example.com">
      </div>
      <div class="form-group">
        <label for="login-password">Password</label>
        <input type="password" id="login-password" required autocomplete="current-password" placeholder="••••••••">
      </div>
      <!-- Honeypot -->
      <input type="text" id="login-honeypot" name="website" style="display:none" tabindex="-1" autocomplete="off">
      <input type="hidden" id="login-form-started" value="">
      <input type="hidden" id="login-captcha-token" value="">

      <!-- GripCaptcha container -->
      <div id="login-gripcaptcha" style="margin:1rem 0;"></div>

      <div id="login-error" class="form-error"></div>
      <button type="submit" class="btn-primary">
        <span class="btn-text">Sign In</span>
        <span class="btn-loader" style="display:none;">⋯</span>
      </button>
    </form>

    <!-- Register Form -->
    <form id="register-form" class="auth-form" autocomplete="on">
      <div class="form-group">
        <label for="register-email">Email</label>
        <input type="email" id="register-email" required autocomplete="email" placeholder="you@example.com">
      </div>
      <div class="form-group">
        <label for="register-password">Password</label>
        <input type="password" id="register-password" required autocomplete="new-password" placeholder="8+ characters" minlength="8">
        <div id="password-strength" class="password-strength"></div>
      </div>
      <div class="form-group">
        <label for="register-password-confirm">Confirm Password</label>
        <input type="password" id="register-password-confirm" required autocomplete="new-password" placeholder="••••••••">
      </div>
      <!-- Honeypot -->
      <input type="text" id="register-honeypot" name="website" style="display:none" tabindex="-1" autocomplete="off">
      <input type="hidden" id="register-form-started" value="">
      <input type="hidden" id="register-captcha-token" value="">

      <!-- GripCaptcha container -->
      <div id="register-gripcaptcha" style="margin:1rem 0;"></div>

      <div id="register-error" class="form-error"></div>
      <div id="register-success" class="form-success"></div>
      <button type="submit" class="btn-primary">
        <span class="btn-text">Create Account</span>
        <span class="btn-loader" style="display:none;">⋯</span>
      </button>
    </form>

    <!-- Dashboard (shown after login) -->
    <div id="dashboard" style="display:none;">
      <div class="dashboard-header">
        <div class="user-avatar" id="user-initial">?</div>
        <div>
          <div id="dashboard-email" style="font-weight:600;"></div>
          <div style="font-size:0.8rem;color:var(--text-muted);">Authenticated</div>
        </div>
      </div>

      <div class="token-section">
        <div class="token-label">
          <span>Access Token</span>
          <span id="token-expiry" style="font-size:0.75rem;color:var(--text-muted);"></span>
        </div>
        <div class="token-display">
          <code id="token-preview" class="token-preview">••••••••••••••••••••••••••••••••</code>
        </div>
        <div class="token-actions">
          <button id="btn-show-token" class="btn-small">👁 Show</button>
          <button id="btn-copy-token" class="btn-small">📋 Copy</button>
          <button id="btn-refresh" class="btn-small">🔄 Refresh now</button>
        </div>
      </div>

      <div class="sessions-section">
        <h3 style="font-size:0.9rem;margin-bottom:0.75rem;">Active Sessions</h3>
        <div id="sessions-list"></div>
      </div>

      <div style="margin-top:1.5rem;display:flex;gap:0.75rem;">
        <button id="btn-logout" class="btn-outline" style="flex:1;">Sign Out</button>
        <button id="btn-logout-all" class="btn-outline btn-danger" style="flex:1;">Sign Out All</button>
      </div>
    </div>
  </div>
</div>

<!-- Footer -->
<div style="text-align:center;padding:1rem 0 1.5rem;">
  <a href="https://github.com/SewellHub" target="_blank" style="color:#00d4ff;font-size:0.82rem;text-decoration:none;">GitHub</a>
  <span style="color:#3a4a5c;margin:0 0.5rem;">·</span>
  <a href="https://gameai.uk" target="_blank" style="color:#8b9cb6;font-size:0.82rem;text-decoration:none;">GameAi</a>
  <span style="color:#3a4a5c;margin:0 0.5rem;">·</span>
  <a href="https://jaffaai.co.uk" target="_blank" style="color:#8b9cb6;font-size:0.82rem;text-decoration:none;">jaffaAi</a>
</div>

<!-- GripCaptcha Widget (replaces Google reCAPTCHA) -->
<script src="https://cp.gamegrip.cloud/grip-captcha.js"></script>
<script src="/js/portal.js"></script>
</body>
</html>
